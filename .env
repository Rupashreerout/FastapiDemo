# Database Configuration
# For SQLite (quick start - no setup needed):
DATABASE_URL=sqlite:///./hrms.db

# For PostgreSQL (update with your credentials):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/hrms_db

# Application Settings
APP_NAME=HRMS Lite API
APP_VERSION=1.0.0
DEBUG=False

# CORS Settings
CORS_ORIGINS=*
